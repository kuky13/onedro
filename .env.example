# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration (Edge Functions)
# Configure these in Supabase Dashboard > Edge Functions > Environment Variables
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# VAPID Keys for Push Notifications
# Generate these keys using: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Email for VAPID (required by web-push specification)
VAPID_EMAIL=mailto:your-email@example.com

# Sentry - Monitoramento de erros em produção
# Obtenha o DSN em https://sentry.io > Settings > Projects > DSN
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Development
NODE_ENV=development