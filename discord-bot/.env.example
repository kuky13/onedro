# ─── Obrigatório ──────────────────────────────────────────────────────────────

# Token do bot Discord
# Obter em: https://discord.com/developers/applications → seu app → Bot → Token
DISCORD_TOKEN=seu_token_aqui

# Chave da API da Anthropic (Claude)
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Opcional ─────────────────────────────────────────────────────────────────

# Modelo do Claude a usar (padrão: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# IDs dos canais de suporte onde a Drippy responde automaticamente (sem @mention)
# Para pegar o ID: ative "Modo Desenvolvedor" no Discord → clique direito no canal → Copiar ID
# Separe múltiplos IDs por vírgula
# SUPPORT_CHANNEL_IDS=1234567890,9876543210
